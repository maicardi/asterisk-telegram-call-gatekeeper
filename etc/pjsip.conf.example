; /etc/asterisk/pjsip.conf example
; Replace USERNAME, PASSWORD, server/proxy and context as needed.
; Tested conceptually with an IPv6-only SIP trunk reachable from the Raspberry network.

[global]
type=global
user_agent=Asterisk-Telegram-Gatekeeper

[transport-udp-ipv6]
type=transport
protocol=udp
bind=[::]:5060

[trunk-auth]
type=auth
auth_type=userpass
username=USERNAME
password=PASSWORD

[trunk-aor]
type=aor
contact=sip:USERNAME@SIP_PROXY:5060
qualify_frequency=0

[trunk-endpoint]
type=endpoint
transport=transport-udp-ipv6
context=from-iliad
disallow=all
allow=alaw
allow=ulaw
outbound_auth=trunk-auth
aors=trunk-aor
from_user=USERNAME
from_domain=SIP_DOMAIN
contact_user=USERNAME
rewrite_contact=yes
rtp_symmetric=yes
force_rport=yes
direct_media=no

[trunk-identify]
type=identify
endpoint=trunk-endpoint
match=SIP_PROXY_IPV6/128

[trunk-registration]
type=registration
transport=transport-udp-ipv6
outbound_auth=trunk-auth
server_uri=sip:SIP_DOMAIN
client_uri=sip:USERNAME@SIP_DOMAIN
contact_user=USERNAME
outbound_proxy=sip:SIP_PROXY\;lr
retry_interval=60
forbidden_retry_interval=60
expiration=3600
line=yes
endpoint=trunk-endpoint
